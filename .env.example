TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# Signal server — contact maintainer for access
SIGNAL_SERVER_URL=https://api.thecharon.xyz/api
SIGNAL_SERVER_KEY=
SIGNAL_POLL_MS=45000

# Helius RPC — required for live execution; free tier works for dry_run
HELIUS_API_KEY=
SOLANA_RPC_URL=
SOLANA_WS_URL=

# GMGN enrichment — set GMGN_ENABLED=false to skip (falls back to Jupiter data)
GMGN_ENABLED=true
GMGN_API_KEY=
GMGN_REQUEST_DELAY_MS=2500
GMGN_MAX_RETRIES=2

DB_PATH=./charon.sqlite
TRADING_MODE=dry_run

# Live / confirm execution — wallet + Jupiter API key required
SOLANA_PRIVATE_KEY=
JUPITER_API_KEY=
JUPITER_SWAP_BASE_URL=https://api.jup.ag/swap/v2
LIVE_MIN_SOL_RESERVE=0.02

# LLM — any OpenAI-compatible endpoint; MiniMax M2.7 is the default
ENABLE_LLM=true
LLM_BASE_URL=https://api.minimax.io/v1
LLM_API_KEY=
LLM_MODEL=MiniMax-M2.7
LLM_TIMEOUT_MS=60000
LLM_CANDIDATE_PICK_COUNT=10
LLM_CANDIDATE_MAX_AGE_MS=600000
MAX_OPEN_POSITIONS=3

MIN_FEE_CLAIM_SOL=2
GRADUATED_POLL_MS=30000
GRADUATED_LOOKBACK_MS=7200000
TRENDING_POLL_MS=60000
TRENDING_LOOKBACK_MS=600000
TRENDING_ENABLED=true
TRENDING_SOURCE=jupiter
TRENDING_ALLOW_DEGEN=false
TRENDING_INTERVAL=5m
TRENDING_LIMIT=100
TRENDING_ORDER_BY=volume
TRENDING_MIN_VOLUME_USD=0
TRENDING_MIN_SWAPS=0
TRENDING_MAX_RUG_RATIO=0.3
TRENDING_MAX_BUNDLER_RATE=0.5
GMGN_CACHE_TTL_MS=300000
POSITION_CHECK_MS=8000

# LP Agent — wallet intelligence enrichment (copy from Meridian .env)
LPAGENT_API_KEY=

# Daily report interval (default 24h)
REPORT_INTERVAL_MS=86400000

PUMPPORTAL_ENABLED=true

# Smart money wallet tracking
SMART_MONEY_ENABLED=true
SIGNAL_POLLER_ENABLED=true
SMART_MONEY_POLL_MS=60000

# Birdeye API — required for mid-cap pool registry
BIRDEYE_API_KEY=

# Helius webhook mode — real-time on-chain swap detection
WEBHOOK_PUBLIC_URL=https://charon-bot-production-9b50.up.railway.app
MIN_WEBHOOK_SOL_THRESHOLD=2.0
POOL_REFRESH_INTERVAL_MS=1800000  # refresh pool list every 30 minutes

# Pivot date — used by /pnl and /drystat to show "SINCE PIVOT" stats alongside all-time.
# Set to ISO UTC string or Unix ms timestamp of your strategy pivot.
PIVOT_DATE=2026-05-20T00:00:00.000Z

# Clean-slate migration — set PIVOT_CLEAN=true for ONE deploy to wipe trade history.
# Protected by a DB flag: runs exactly once, then is a no-op even if still set.
# Set back to false after deploy to keep config clean.
PIVOT_CLEAN=false

# Full reset — wipes all trade/lesson data, keeps blacklist and settings.
# Set FULL_RESET=true for ONE deploy, then set back to false immediately.
FULL_RESET=false

# Lesson reset — wipes learning_lessons and route_weights (except proven routes).
# Runs every startup while true — set back to false after first deploy.
RESET_LESSONS=false

# Disabled signal routes — comma-separated canonical route names
DISABLED_ROUTES=dual_source,webhook

# Webhook momentum gate — set false to disable webhook as a momentum signal source
WEBHOOK_MOMENTUM_ENABLED=false

# Starting dry-run balance — used as baseline in /pnl balance display.
# Set to your actual wallet SOL at pivot time.
DRY_RUN_STARTING_BALANCE=0.45

# Accelerated dry-run mode — compresses 30-day learning to 3-5 days
ACCELERATED_DRY_RUN=false
POSITION_PRICE_CHECK_INTERVAL_MS=120000   # 2-min price checks (vs 8s default)
DEXSCREENER_TRENDING_POLL_MS=600000       # poll DexScreener trending every 10min

# Backtest engine — simulates 150–300 historical trades
BACKTEST_AUTO_RUN=false         # auto-run backtest on startup
BACKTEST_LOOKBACK_HOURS=72      # 72h lookback window
BACKTEST_MAX_CANDIDATES=300     # max tokens to scan

# Candidate filter thresholds (free data — no Birdeye required)
FILTER_MIN_LIQUIDITY_USD=25000      # min pool liquidity
FILTER_MIN_TOKEN_AGE_HOURS=24       # token must be at least 24h old
FILTER_MAX_TOP10_HOLDER_PCT=30      # max top-10 holder concentration
FILTER_MAX_DEV_WALLET_PCT=10        # max single wallet concentration
FILTER_MIN_MOMENTUM_SIGNALS=3       # min number of positive momentum signals
FILTER_MAX_SLIPPAGE_PCT=2.0         # max acceptable Jupiter slippage
FILTER_MIN_BUY_SELL_RATIO=1.6       # min buy/sell ratio (buying pressure) — raised from 1.4
FILTER_MIN_VOLUME_MCAP_RATIO=0.08   # min 24h volume / mcap ratio — raised from 0.05
FILTER_WEBHOOK_MIN_SOL=2.0          # min SOL in webhook swap to trigger signal
TRADING_HOURS_UTC=10,11,16,18,19    # UTC hours when new positions are allowed (comma-separated)
MAX_CANDIDATE_SCORE=65              # score ceiling — tokens scoring above this are filtered (crowded)
LOSS_COOLDOWN_MS=7200000            # cooldown after a loss exit before re-entering same mint (ms)
TRAIL_ENABLED=true                  # enable profit-lock trailing stop (set false for original flat TP)
TRAIL_PCT=0.10                      # pullback % from peak that triggers trail exit (default: 10%)
SIMULATE_COSTS=true                 # simulate slippage/gas/MEV on dry-run trades (set false to disable)
TX_TIMEOUT_MS=30000                 # max ms a buy/sell lock can be held before auto-release
SIMULATE_TX_DELAYS=true             # simulate network/confirmation latency on dry-run entries (set false to disable)
MAX_RETRY_ATTEMPTS=1                # max buy retry attempts on transient failures (live mode only)
SLIPPAGE_BPS=300                    # max entry slippage tolerance in basis points (3%)
PRIORITY_FEE_LAMPORTS=50000         # priority fee per transaction in lamports (~0.00005 SOL)
LIQUIDITY_EMERGENCY_USD=10000       # force-close if pool liquidity drops below this threshold
LIQUIDITY_WARNING_USD=20000         # log a warning if pool liquidity drops below this threshold
